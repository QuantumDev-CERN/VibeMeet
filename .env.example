# .env.example

# Postgres
DATABASE_URL=postgresql://VibeMeet:VibeMeet@localhost:5432/VibeMeet

# JWT
JWT_SECRET=your_secret_here
JWT_EXPIRES_IN=7d

# Cloudflare R2
R2_ACCOUNT_ID=
